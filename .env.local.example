# Site Configuration
NEXT_PUBLIC_SITE_URL=https://fstivo.com
NEXT_PUBLIC_APP_NAME=Fstivo

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# OAuth Providers (Configure in Supabase Dashboard)
# Enable Google/Facebook OAuth in Supabase > Authentication > Providers
# Redirect URLs: http://localhost:3000/auth/callback (dev), https://yourdomain.com/auth/callback (prod)
NEXT_PUBLIC_AUTH_CALLBACK_URL=/auth/callback

# Payment Gateways
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

JAZZCASH_MERCHANT_ID=your_merchant_id
JAZZCASH_PASSWORD=your_password
EASYPAISA_STORE_ID=your_store_id
EASYPAISA_SECRET_KEY=your_secret_key

# Email Service (Resend)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_...
# The verified domain email from which emails will be sent
RESEND_FROM_EMAIL=noreply@yourdomain.com
# Public URL for the app (used in email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =====================================================
# NOTIFICATION SYSTEM
# =====================================================

# Twilio (SMS & WhatsApp)
# Get credentials from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Web Push Notifications (VAPID)
# Generate VAPID keys using: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BEl62iUYgUivxIkv69yViEuiBIa-Ib37gp9NgWmLHn...
VAPID_PRIVATE_KEY=UUxI4O8-FbRouAevSmBQ6o8l5-g-p...
VAPID_SUBJECT=mailto:admin@fstivo.com

# Notification Settings
# Development mode (set to 'true' to skip actual sending)
DEV_MODE_NOTIFICATIONS=false
DEV_LOG_NOTIFICATIONS=true

# Cron Job Security (Optional but recommended)
# Generate a random secret: openssl rand -base64 32
CRON_SECRET=your_random_secret_here

# AI Services
OPENAI_API_KEY=sk-...
