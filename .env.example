# ==============================================
# FSTIVO ENVIRONMENT VARIABLES - COMPLETE
# ==============================================

# ============== APPLICATION ==============
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=FSTIVO
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============== DATABASE ==============
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here
DATABASE_URL=postgresql://postgres:password@localhost:54322/postgres

# ============== AUTHENTICATION ==============
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_generate_with_openssl_rand_base64_32

# ============== PAYMENTS ==============
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

JAZZCASH_MERCHANT_ID=your_jazzcash_merchant_id
JAZZCASH_PASSWORD=your_jazzcash_password
JAZZCASH_INTEGRITY_SALT=your_jazzcash_integrity_salt

EASYPAISA_STORE_ID=your_easypaisa_store_id
EASYPAISA_SECRET_KEY=your_easypaisa_secret_key

# ============== EMAIL ==============
RESEND_API_KEY=re_your_resend_api_key
NEXT_PUBLIC_RESEND_FROM_EMAIL=noreply@fstivo.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# ============== SMS & MESSAGING ==============
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ============== PUSH NOTIFICATIONS ==============
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:support@fstivo.com

# Cron / webhook secret - used to verify inbound webhooks and scheduled jobs
# Generate with: openssl rand -base64 32
CRON_SECRET=your_cron_secret_here

# ============== CACHING ==============
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ============== MAPS & LOCATION ==============
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token

# ============== ANALYTICS & MONITORING ==============
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_SENTRY_DSN=https://your_sentry_dsn@sentry.io/project

# ============== AI & MACHINE LEARNING ==============
OPENAI_API_KEY=sk-your_openai_api_key

# ============== SOCIAL AUTHENTICATION ==============
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ============== SECURITY ==============
ENCRYPTION_KEY=your_32_char_encryption_key_here
HASH_SALT=your_hash_salt_rounds_10_or_12

# ============== FEATURE FLAGS ==============
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_SOCIAL=true
NEXT_PUBLIC_ENABLE_2FA=true

# ============== DEVELOPMENT ==============
DEV_MODE=true
DEV_LOG_NOTIFICATIONS=true

# ============== SUPPORT ==============
SUPPORT_EMAIL=support@fstivo.com
