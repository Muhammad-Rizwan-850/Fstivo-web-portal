# Site Configuration
NEXT_PUBLIC_SITE_URL=https://fstivo.com
NEXT_PUBLIC_APP_NAME=Fstivo

# ⚠️ REQUIRED: Replace with your actual Supabase credentials
# Get these from: https://supabase.com/dashboard/project/_/settings/api

# Test Supabase (local/test placeholders)
NEXT_PUBLIC_SUPABASE_URL=https://test.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJtestanonkey

# Service Role Key (for server-side operations)
SUPABASE_SERVICE_ROLE_KEY=eyJserviceRoleKey

# OAuth Providers (Configure in Supabase Dashboard)
# Enable Google/Facebook OAuth in Supabase > Authentication > Providers
# Redirect URLs: http://localhost:3000/auth/callback (dev), https://yourdomain.com/auth/callback (prod)
NEXT_PUBLIC_AUTH_CALLBACK_URL=/auth/callback

# Payment Gateways (Optional - for payment processing)
STRIPE_SECRET_KEY=sk_test_1234567890
STRIPE_WEBHOOK_SECRET=whsec_test_123
STRIPE_PUBLISHABLE_KEY=pk_test_123
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_123

JAZZCASH_MERCHANT_ID=TEST_MERCHANT
JAZZCASH_PASSWORD=TEST_PASSWORD
EASYPAISA_STORE_ID=TEST_STORE
